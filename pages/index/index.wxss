.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
}

.hero-card,
.book-card {
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.hero-card {
  padding: 32rpx;
  margin-bottom: 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(244, 248, 252, 0.98) 100%);
}

.hero-badge,
.book-chip {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(22, 163, 74, 0.1);
  color: #166534;
  font-size: 22rpx;
}

.hero-dot {
  width: 14rpx;
  height: 14rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #22c55e;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 46rpx;
  font-weight: 700;
  color: #0f172a;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #64748b;
}

.book-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
}

.book-card {
  position: relative;
  overflow: hidden;
  min-height: 460rpx;
  border-radius: 32rpx;
  background: #ffffff;
}

.book-cover,
.book-card-overlay {
  position: absolute;
  inset: 0;
}

.book-card-overlay {
  background: linear-gradient(180deg, rgba(248, 250, 252, 0.04) 0%, rgba(248, 250, 252, 0.6) 62%, rgba(255, 255, 255, 0.92) 100%);
}

.book-card-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 22rpx;
}

.book-name {
  margin-top: 18rpx;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #0f172a;
}

.book-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.book-meta {
  font-size: 22rpx;
  color: #64748b;
}

.book-card-arrow {
  width: 28rpx;
  height: 28rpx;
}

.empty,
.loading {
  margin-top: 80rpx;
  text-align: center;
  color: #64748b;
}

.empty-icon {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto;
}

.empty-text {
  margin-top: 14rpx;
  font-size: 26rpx;
}
