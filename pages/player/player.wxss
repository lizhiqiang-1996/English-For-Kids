page {
  background: #f8fafc;
}

.player-page {
  min-height: 100vh;
  padding: 32rpx 24rpx 96rpx;
  background: #f8fafc;
}

.player-page-info,
.player-progress-card,
.player-volume-card {
  width: 100%;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.player-page-info {
  padding: 30rpx 28rpx 34rpx;
  text-align: center;
}

.player-page-badge {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(22, 163, 74, 0.1);
  color: #166534;
  font-size: 22rpx;
}

.player-page-dot {
  width: 14rpx;
  height: 14rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #22c55e;
}

.player-cover-shell {
  width: 480rpx;
  height: 480rpx;
  margin: 24rpx auto 28rpx;
  padding: 18rpx;
  border-radius: 44rpx;
  background: linear-gradient(180deg, rgba(248, 250, 252, 1) 0%, rgba(236, 253, 245, 0.92) 100%);
  box-shadow: 0 22rpx 48rpx rgba(15, 23, 42, 0.08);
}

.player-page-cover {
  width: 100%;
  height: 100%;
  border-radius: 30rpx;
}

.player-page-meta {
  font-size: 24rpx;
  font-weight: 600;
  color: #16a34a;
}

.player-page-content-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 14rpx;
  text-align: left;
}

.player-page-text {
  flex: 1;
  min-width: 0;
}

.player-page-book-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.player-page-book {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  font-weight: 600;
  color: #64748b;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.player-back-audio-btn {
  min-width: 128rpx;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  color: #475569;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.player-page-title {
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #0f172a;
}

.player-favorite-btn {
  min-width: 128rpx;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.player-favorite-btn.active {
  background: #fff1f2;
  border-color: #fecdd3;
}

.player-favorite-icon {
  width: 30rpx;
  height: 30rpx;
}

.player-favorite-text {
  margin-left: 10rpx;
  font-size: 22rpx;
  color: #475569;
}

.player-favorite-btn.active .player-favorite-text {
  color: #e11d48;
}

.player-page-duration {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.player-progress-card,
.player-volume-card {
  padding: 26rpx 28rpx;
  margin-top: 24rpx;
}

.player-section-head {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.player-section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #0f172a;
}

.player-section-value {
  font-size: 22rpx;
  color: #16a34a;
}

.player-progress-bar,
.player-volume-bar {
  position: relative;
  height: 12rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
}

.player-progress-fill,
.player-volume-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #22c55e 0%, #16a34a 100%);
}

.player-progress-thumb,
.player-volume-thumb {
  position: absolute;
  top: 50%;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 6rpx solid #22c55e;
  box-shadow: 0 4rpx 14rpx rgba(34, 197, 94, 0.18);
  transform: translate(-50%, -50%);
}

.player-progress-time {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #64748b;
}

.player-volume-row {
  display: flex;
  align-items: center;
  width: 100%;
}

.player-volume-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.player-volume-bar {
  flex: 1;
}

.player-page-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 34rpx;
  margin: 38rpx 0;
}

.player-control-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.08);
}

.player-play-btn {
  width: 136rpx;
  height: 136rpx;
  background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);
}

.player-control-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.player-play-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.player-empty {
  margin-top: 180rpx;
  text-align: center;
  color: #64748b;
}

.player-empty-icon-shell {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto 18rpx;
  border-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.player-empty-icon {
  width: 56rpx;
  height: 56rpx;
}
