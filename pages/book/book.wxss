.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
}

.book-header,
.unit-panel {
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.book-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.98);
}

.book-cover {
  width: 154rpx;
  height: 208rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.book-info {
  margin-left: 24rpx;
  min-width: 0;
}

.book-badge {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(22, 163, 74, 0.1);
  color: #166534;
  font-size: 22rpx;
}

.book-dot {
  width: 14rpx;
  height: 14rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #22c55e;
}

.book-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #0f172a;
}

.book-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.unit-panel {
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.98);
}

.unit-row,
.lesson-row,
.unit-left,
.unit-right,
.lesson-left,
.lesson-right {
  display: flex;
  align-items: center;
}

.unit-row,
.lesson-row {
  justify-content: space-between;
}

.unit-row {
  padding: 28rpx 26rpx;
  border-bottom: 1rpx solid #e9eff5;
}

.lesson-panel {
  background: #f8fbff;
}

.lesson-row {
  padding: 22rpx 26rpx 22rpx 38rpx;
  border-top: 1rpx solid #edf2f7;
}

.unit-icon,
.lesson-icon,
.unit-arrow {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.unit-icon,
.lesson-icon {
  margin-right: 18rpx;
}

.unit-name,
.lesson-name {
  color: #0f172a;
}

.unit-name {
  font-size: 32rpx;
  font-weight: 600;
}

.lesson-name {
  font-size: 27rpx;
}

.unit-lessons,
.lesson-count {
  margin-right: 14rpx;
  font-size: 22rpx;
  color: #64748b;
}

.audio-panel {
  padding: 0 18rpx 18rpx;
}

.audio-row {
  display: flex;
  align-items: center;
  margin: 14rpx 0 0 48rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #edf2f7;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.04);
}

.audio-cover {
  width: 82rpx;
  height: 82rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.audio-main {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.audio-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.audio-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.audio-play-shell {
  width: 60rpx;
  height: 60rpx;
  margin-left: 14rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-play {
  width: 30rpx;
  height: 30rpx;
}

.empty,
.loading {
  margin-top: 80rpx;
  text-align: center;
  color: #64748b;
}

.empty-icon {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto;
}

.empty-text {
  margin-top: 14rpx;
  font-size: 26rpx;
}
