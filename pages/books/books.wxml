<view class="page">
  <view class="hero-card" wx:if="{{!selectedBookKey}}">
    <view class="hero-badge">
      <view class="hero-dot"></view>
      <text>English for KIDS</text>
    </view>
    <view class="hero-title">课本音频库</view>
  </view>

  <view class="book-detail" wx:if="{{selectedBookKey}}">
    <view class="book-header">
      <view class="book-back" bindtap="onBackToBooks">
        <image class="book-back-icon" src="/img/arrow-left-dark.svg" mode="aspectFit" />
        <text class="book-back-text">返回课本</text>
      </view>
      <view class="book-header-main">
        <image class="detail-cover" src="{{selectedBookCover}}" mode="aspectFill" />
        <view class="detail-info">
          <view class="detail-badge">
            <view class="detail-dot"></view>
            <text>Book Detail</text>
          </view>
          <view class="detail-title">{{selectedBookTitle}}</view>
          <view class="detail-desc">{{unitGroups.length}} 个 Unit</view>
        </view>
      </view>
    </view>

    <view class="unit-panel" wx:if="{{unitGroups.length > 0}}">
      <block wx:for="{{unitGroups}}" wx:key="unitLabel" wx:for-item="group">
        <view class="unit-row" bindtap="onToggleUnit" data-unit="{{group.unitLabel}}">
          <view class="unit-left">
            <image class="unit-icon" src="/img/book-outline-dark.svg" mode="aspectFit" />
            <text class="unit-name">{{group.unitLabel}}</text>
          </view>
          <view class="unit-right">
            <text class="unit-lessons">{{group.lessons.length}} 课次</text>
            <image class="unit-arrow" src="{{group.open ? '/img/chevron-down-dark.svg' : '/img/chevron-right-dark.svg'}}" mode="aspectFit" />
          </view>
        </view>

        <view class="lesson-panel" wx:if="{{group.open}}">
          <block wx:for="{{group.lessons}}" wx:key="lesson" wx:for-item="lesson">
            <view class="lesson-row" bindtap="onToggleLesson" data-unit="{{group.unitLabel}}" data-lesson="{{lesson.lesson}}">
              <view class="lesson-left">
                <image class="lesson-icon" src="/img/layers-outline-dark.svg" mode="aspectFit" />
                <text class="lesson-name">{{lesson.lesson}}</text>
              </view>
              <view class="lesson-right">
                <text class="lesson-count">{{lesson.items.length}} 条</text>
                <image class="unit-arrow" src="{{lesson.open ? '/img/chevron-down-dark.svg' : '/img/chevron-right-dark.svg'}}" mode="aspectFit" />
              </view>
            </view>

            <view class="audio-panel" wx:if="{{lesson.open}}">
              <block wx:for="{{lesson.items}}" wx:key="id" wx:for-item="audio">
                <view id="audio-{{audio.id}}" class="audio-row {{currentAudioId === audio.id ? 'audio-row-active' : ''}}" bindtap="onAudioTap" data-id="{{audio.id}}">
                  <image class="audio-cover" src="{{audio.coverUrl}}" mode="aspectFill" />
                  <view class="audio-main">
                    <view class="audio-title">{{audio.title}}</view>
                    <view class="audio-subtitle">{{audio.unitLabel}} · {{audio.lesson}}</view>
                  </view>
                  <view class="audio-actions">
                    <view class="audio-favorite-btn {{audio.isFavorited ? 'active' : ''}}" catchtap="onFavoriteTap" data-id="{{audio.id}}">
                      <image class="audio-favorite-icon" src="{{audio.isFavorited ? '/img/heart-solid.svg' : '/img/heart-outline-dark.svg'}}" mode="aspectFit" />
                    </view>
                    <view class="audio-status" wx:if="{{currentAudioId === audio.id}}">
                      <text class="audio-status-text">{{isPlaying ? '播放中' : '已暂停'}}</text>
                    </view>
                    <view class="audio-play-shell" wx:else>
                      <image class="audio-play" src="/img/play-dark.svg" mode="aspectFit" />
                    </view>
                  </view>
                </view>
              </block>
            </view>
          </block>
        </view>
      </block>
    </view>
  </view>

  <view class="book-section" wx:elif="{{bookGroups.length > 0}}">
    <view class="book-list">
      <block wx:for="{{bookGroups}}" wx:key="bookKey" wx:for-item="book">
        <view class="book-card" bindtap="onSelectBook" data-book-key="{{book.bookKey}}">
          <image class="book-cover" src="{{book.cover}}" mode="aspectFill" />
          <view class="book-card-overlay"></view>
          <view class="book-card-content">
            <view class="book-name">{{book.title}}</view>
            <view class="book-meta-row">
              <view class="book-meta">{{book.totalCount}} 条音频</view>
              <image class="book-card-arrow" src="/img/chevron-right-dark.svg" mode="aspectFit" />
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="empty" wx:if="{{bookGroups.length === 0 && !loading}}">
    <image class="empty-icon" src="/img/audio-empty.svg" mode="aspectFit" />
    <view class="empty-text">暂无教材音频</view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="mini-player" wx:if="{{currentAudioId}}" bindtap="onMiniPlayerTap">
    <view class="mini-player-main">
      <view class="mini-player-badge"></view>
      <view class="mini-player-info">
        <view class="mini-player-title">{{currentAudioTitle}}</view>
        <view class="mini-player-subtitle">{{currentAudioSubtitle || '当前正在播放'}}</view>
      </view>
    </view>
    <view class="mini-player-actions">
      <view class="mini-player-btn" catchtap="onMiniPlayTap">
        <image class="mini-player-btn-icon" src="{{isPlaying ? '/img/pause-white.svg' : '/img/play-white.svg'}}" mode="aspectFit" />
      </view>
      <view class="mini-player-open">打开</view>
    </view>
  </view>
</view>
