.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 200rpx;
}

.hero-card,
.book-header-main,
.unit-panel,
.book-card {
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.hero-card {
  padding: 32rpx;
  margin-bottom: 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(244, 248, 252, 0.98) 100%);
}

.hero-badge,
.detail-badge,
.book-chip {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(22, 163, 74, 0.1);
  color: #166534;
  font-size: 22rpx;
}

.hero-dot,
.detail-dot,
.mini-player-badge {
  width: 14rpx;
  height: 14rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #22c55e;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #0f172a;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #64748b;
}

.book-header {
  margin-bottom: 28rpx;
}

.book-back {
  display: inline-flex;
  align-items: center;
  height: 66rpx;
  padding: 0 22rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.book-back-icon {
  width: 28rpx;
  height: 28rpx;
}

.book-back-text {
  margin-left: 10rpx;
  font-size: 24rpx;
  color: #0f172a;
}

.book-header-main {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.98);
}

.detail-cover {
  width: 154rpx;
  height: 208rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.detail-info {
  margin-left: 24rpx;
  min-width: 0;
}

.detail-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #0f172a;
}

.detail-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.book-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
}

.book-card {
  position: relative;
  overflow: hidden;
  min-height: 460rpx;
  border-radius: 32rpx;
  background: #ffffff;
}

.book-cover,
.book-card-overlay {
  position: absolute;
  inset: 0;
}

.book-cover {
  width: 100%;
  height: 100%;
  display: block;
  opacity: 0.78;
  transform: scale(1.24);
  transform-origin: 58% 44%;
}

.book-card-overlay {
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.02) 0%,
    rgba(255, 255, 255, 0.08) 42%,
    rgba(255, 255, 255, 0.46) 68%,
    rgba(255, 255, 255, 0.86) 100%
  );
}

.book-card-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 22rpx;
}

.book-name {
  margin-top: 18rpx;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #0f172a;
}

.book-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.book-meta {
  font-size: 22rpx;
  color: #64748b;
}

.book-card-arrow {
  width: 28rpx;
  height: 28rpx;
}

.unit-panel {
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.98);
}

.unit-row,
.lesson-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.unit-row {
  padding: 28rpx 26rpx;
  border-bottom: 1rpx solid #e9eff5;
}

.lesson-panel {
  background: #f8fbff;
}

.lesson-row {
  padding: 22rpx 26rpx 22rpx 38rpx;
  border-top: 1rpx solid #edf2f7;
}

.unit-left,
.unit-right,
.lesson-left,
.lesson-right,
.audio-status {
  display: flex;
  align-items: center;
}

.unit-icon,
.lesson-icon,
.unit-arrow {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.unit-icon,
.lesson-icon {
  margin-right: 18rpx;
}

.unit-name,
.lesson-name {
  color: #0f172a;
}

.unit-name {
  font-size: 32rpx;
  font-weight: 600;
}

.lesson-name {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.2rpx;
  line-height: 1.35;
  color: #1e293b;
}

.unit-lessons,
.lesson-count {
  margin-right: 14rpx;
  font-size: 22rpx;
  color: #64748b;
}

.audio-panel {
  padding: 0 18rpx 18rpx;
}

.audio-row {
  display: flex;
  align-items: center;
  margin: 14rpx 0 0 48rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #edf2f7;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.04);
}

.audio-row-active {
  border-color: rgba(34, 197, 94, 0.28);
  background: linear-gradient(135deg, #f4fff7 0%, #ffffff 100%);
}

.audio-cover {
  width: 82rpx;
  height: 82rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.audio-main {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.audio-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.audio-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.audio-status-text {
  font-size: 22rpx;
  color: #16a34a;
}

.audio-actions {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.audio-favorite-btn {
  width: 56rpx;
  height: 56rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-favorite-btn.active {
  background: #fff1f2;
}

.audio-favorite-icon {
  width: 28rpx;
  height: 28rpx;
}

.audio-play-shell {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-play {
  width: 30rpx;
  height: 30rpx;
}

.mini-player {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: #081221;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  box-shadow: 0 20rpx 40rpx rgba(15, 23, 42, 0.22);
  overflow: hidden;
  z-index: 40;
}

.mini-player-main,
.mini-player-actions {
  display: flex;
  align-items: center;
}

.mini-player-main {
  flex: 1;
  min-width: 0;
}

.mini-player-info {
  flex: 1;
  min-width: 0;
}

.mini-player-title {
  font-size: 28rpx;
  color: #f8fafc;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mini-player-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.66);
}

.mini-player-btn,
.mini-player-open {
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-player-btn {
  width: 72rpx;
  background: rgba(148, 163, 184, 0.16);
}

.mini-player-btn-icon {
  width: 32rpx;
  height: 32rpx;
}

.mini-player-open {
  min-width: 92rpx;
  padding: 0 20rpx;
  margin-left: 12rpx;
  background: rgba(148, 163, 184, 0.16);
  color: #f8fafc;
  font-size: 24rpx;
}

.empty,
.loading {
  margin-top: 80rpx;
  text-align: center;
  color: #64748b;
}

.empty-icon {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto;
}

.empty-text {
  margin-top: 14rpx;
  font-size: 26rpx;
}
